{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores extended user information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "addresses": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "label": { "type": "string", "description": "e.g., Home, Office" },
              "fullName": { "type": "string" },
              "street": { "type": "string" },
              "city": { "type": "string" },
              "state": { "type": "string" },
              "zipCode": { "type": "string" },
              "country": { "type": "string" },
              "isDefault": { "type": "boolean" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Order": {
      "title": "Order",
      "description": "Stores customer orders",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "name": { "type": "string" },
              "price": { "type": "number" },
              "quantity": { "type": "integer" },
              "image": { "type": "string" }
            }
          }
        },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered", "cancelled"] },
        "shippingAddress": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "items", "totalAmount", "status", "createdAt"]
    },
    "WishlistItem": {
      "title": "Wishlist Item",
      "description": "Stores items saved to user wishlist",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "productId": { "type": "string" },
        "addedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "productId", "addedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile documents"
    },
    "/orders": {
      "schema": "Order",
      "description": "Global orders collection"
    },
    "/wishlist": {
      "schema": "WishlistItem",
      "description": "Global wishlist collection"
    }
  }
}
